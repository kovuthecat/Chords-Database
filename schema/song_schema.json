{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "song_schema",
  "title": "Song",
  "description": "Format officiel d'entrée du projet Chords (v2). Le projet consomme un JSON conforme à ce format ; il ne le génère pas. Référence : song_template_with_rhythm.json.",
  "type": "object",
  "required": ["meta", "sections", "structure_sequence"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["title", "artist", "slug"],
      "properties": {
        "title":          { "type": "string" },
        "artist":         { "type": "string" },
        "slug":           { "type": "string" },
        "album":          { "type": ["string", "null"] },
        "version":        { "type": ["string", "null"] },
        "key":            { "type": ["string", "null"] },
        "key_mode":       { "type": ["string", "null"] },
        "capo":           { "type": "integer", "minimum": 0 },
        "tempo":          { "type": ["integer", "null"] },
        "time_signature": { "type": "string" },
        "tuning":         { "type": "string" }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name":  { "type": "string" },
          "type":  { "type": "string" },
          "url":   { "type": ["string", "null"] },
          "key":   { "type": ["string", "null"] },
          "capo":  { "type": "integer" },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "chords_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "structure_sequence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "IDs de sections dans l'ordre de jeu. Peut référencer le même ID plusieurs fois. Les _comment sont ignorés."
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id":            { "type": "string" },
          "type":          { "type": "string" },
          "label":         { "type": "string" },
          "is_instrumental": { "type": "boolean" },
          "chord_grid":    { "type": ["string", "null"] },
          "repeats":       { "type": "integer", "minimum": 1 },
          "summary_progression": { "type": ["string", "null"] },
          "performance_progression": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["chords"],
              "properties": {
                "chords": { "type": "string" },
                "repeat": { "type": "integer", "minimum": 1 }
              }
            }
          },
          "rhythm": {
            "type": ["object", "null"],
            "properties": {
              "pattern": { "type": "string" },
              "feel":    { "type": "string" }
            }
          },
          "lines": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "lyrics": { "type": "string" },
                "chords": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["chord", "position"],
                    "properties": {
                      "chord":    { "type": "string" },
                      "position": { "type": "integer", "minimum": 0 }
                    }
                  }
                }
              }
            }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "message":  { "type": "string" },
          "severity": { "type": "string" }
        }
      }
    },
    "simplification": {
      "type": "object",
      "properties": {
        "has_simplified_version": { "type": "boolean" },
        "chord_substitutions":    { "type": "object" },
        "simplification_notes":   { "type": "array" },
        "mode": { "type": "string" }
      }
    },
    "confidence": {
      "type": "object",
      "properties": {
        "overall":               { "type": "number" },
        "structure":             { "type": "number" },
        "chords":                { "type": "number" },
        "capo":                  { "type": "number" },
        "instrumental_sections": { "type": "number" },
        "lyric_alignment":       { "type": "number" }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "status":           { "type": "string" },
        "validated_at":     { "type": ["string", "null"] },
        "user_corrections": { "type": "array" }
      }
    }
  }
}
