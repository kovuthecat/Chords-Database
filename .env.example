# Chords — Variables d'environnement
# Copier en .env.local pour le développement local.
# Ne JAMAIS committer .env.local.

# ---------------------------------------------------------------------------
# Backend de stockage
# ---------------------------------------------------------------------------
# "local"    : données sur disque (mode dev local, défaut)
# "supabase" : données dans Supabase Postgres + Storage (prod/cloud)
STORAGE_BACKEND=local

# ---------------------------------------------------------------------------
# Supabase (requis si STORAGE_BACKEND=supabase)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_STORAGE_BUCKET=chords-exports

# ---------------------------------------------------------------------------
# Chemins locaux (mode local uniquement)
# ---------------------------------------------------------------------------
# Dossier où sont exportés les PDFs split (Paroles & Accords / Mémo Guitare)
# Si absent, valeur par défaut : racine du repo / output/
PDF_EXPORT_DIR=C:\Users\kovu\SynologyDrive\Thibault\Guitartabs\Chords
